# Synchromessotron configuration example.
# Copy to config.yaml and fill in your values.
# Point the service to this file via:
#   export SYNCHROMESSOTRON_CONFIG=/path/to/config.yaml

sync_state:
  collection: synchromessotron   # Firestore collection name
  document: state                # Firestore document within that collection

sync_pairs:
  # Pair 1: Telegram → VK
  - source:
      messenger: telegram
      account_id: "me"           # "me" = Saved Messages, or use @username / numeric ID
      credentials_ref: TG_CREDS  # name of the env var holding Telegram credentials JSON
    target:
      messenger: vk
      account_id: "123456789"    # VK peer_id: user_id, or 2000000000 + chat_id for groups
      credentials_ref: VK_CREDS  # name of the env var holding VK credentials JSON
    write_strategy: repost       # "repost" (default) or "forward"

  # Pair 2: VK → Telegram (reverse direction)
  - source:
      messenger: vk
      account_id: "123456789"
      credentials_ref: VK_CREDS
    target:
      messenger: telegram
      account_id: "me"
      credentials_ref: TG_CREDS
    write_strategy: repost
